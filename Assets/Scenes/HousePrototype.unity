--- !u!114 &516335432
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 516335431}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 436c1bcb8bb148843abfcbf7ca16918d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DayManager
  dreamCompletionFlags:
  - DreamHallwayComplete
  - WheatFieldPowerRestored
  - HospitalDreamComplete
  - GasStationDreamComplete
  - HouseAfterSleepStarted
  days:
  - dayNumber: 1
    dayStartObjective: Finish your evening routine, then sleep.
    taskLabels:
    - Check the TV
    - Check the answering machine
    - Turn off the kitchen light
    requiredFlagsForSleep:
    - WatchedTV
    - CheckedAnsweringMachine
    - KitchenLightOff
    bedNotReadyMessage: You are not ready to sleep yet.
    dreamSceneToLoad: DreamHallway
    cannotSleepMessage: 
    flagToSetOnSleep: 
    sleepIsEnding: 0
    endingFlag: 
    endingMessage: 
  - dayNumber: 2
    dayStartObjective: Something is different. Check the house, then rest.
    taskLabels:
    - Listen to the new message
    - Look at the bedroom photo
    - Check the bathroom mirror
    - Look in the fridge
    requiredFlagsForSleep:
    - HeardNewMessage
    - SawChangedPhoto
    - SawCoveredMirror
    - CheckedFridge
    bedNotReadyMessage: Not yet. Look at what changed first.
    dreamSceneToLoad: DreamWheatField
    cannotSleepMessage: 
    flagToSetOnSleep: 
    sleepIsEnding: 0
    endingFlag: 
    endingMessage: 
  - dayNumber: 3
    dayStartObjective: The power came back with you. Look around, then rest.
    taskLabels:
    - Look at the TV static
    - Listen to the radio
    - Listen to the buzzing wall
    - Check the fuse room
    requiredFlagsForSleep:
    - SawTVStatic
    - ListenedToRadio
    - FeltWallBuzzing
    - CheckedFuseBox
    bedNotReadyMessage: Not yet. The house is louder than before. Look around.
    dreamSceneToLoad: DreamHospital
    cannotSleepMessage: 
    flagToSetOnSleep: 
    sleepIsEnding: 0
    endingFlag: 
    endingMessage: 
  - dayNumber: 4
    dayStartObjective: Something followed you back from the ward. Look around, then
      rest.
    taskLabels:
    - Read the paper on the kitchen table
    - Listen to the clinic message
    - Check the bathroom cabinet
    - Open the dresser drawer
    requiredFlagsForSleep:
    - ReadMedicalDocument
    - HeardClinicMessage
    - CheckedMedication
    - OpenedMedicalDrawer
    bedNotReadyMessage: Not yet. The house smells like a hospital. Look around.
    dreamSceneToLoad: DreamGasStation
    cannotSleepMessage: 
    flagToSetOnSleep: 
    sleepIsEnding: 0
    endingFlag: 
    endingMessage: 
  - dayNumber: 5
    dayStartObjective: You brought things back from the store. Look around, then
      rest.
    taskLabels:
    - Read the receipt on the counter
    - Play the VHS tape
    - Open the kitchen drawer
    - Try the front door
    requiredFlagsForSleep:
    - ReadKitchenReceipt
    - WatchedVHSTape
    - OpenedKitchenDrawer
    - SawImpossibleRoad
    bedNotReadyMessage: Not yet. The things you bought are waiting.
    dreamSceneToLoad: HousePrototype
    cannotSleepMessage: 
    flagToSetOnSleep: HouseAfterSleepStarted
    sleepIsEnding: 0
    endingFlag: 
    endingMessage: 
  - dayNumber: 6
    dayStartObjective: The dreams came home with you. Put each one back where it
      belongs.
    taskLabels:
    - Put the hallway clock back
    - Seat the field fuse
    - File the patient chart
    - Smooth out the receipt
    - Play the tape one last time
    requiredFlagsForSleep:
    - FinalClockPlaced
    - FinalFusePlaced
    - FinalPatientFilePlaced
    - FinalReceiptPlaced
    - FinalVHSTapePlayed
    bedNotReadyMessage: Not yet. The dreams are still scattered through the rooms.
    dreamSceneToLoad: 
    cannotSleepMessage: 
    flagToSetOnSleep: 
    sleepIsEnding: 1
    endingFlag: EndingGoBackToSleep
    endingMessage: You lie down and let the house keep you. Somewhere close, a small
      voice says goodnight. You say it back.
  currentDay: 1
